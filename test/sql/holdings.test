# name: test/sql/holdings.test
# description: invesco.holdings base table — fund_ticker partition (pushdown), current-only (no time travel).
# group: [sql]

require-env VGI_TEST_WORKER

statement ok
ATTACH 'invesco' AS iv (TYPE vgi, LOCATION '${VGI_TEST_WORKER}');

statement ok
SET search_path='iv.main';

# --- Schema: DESCRIBE binds only (no network). `holdings` is a base TABLE. ---

query T
SELECT string_agg(column_name, ',') FROM (DESCRIBE SELECT * FROM iv.holdings WHERE fund_ticker = 'RSP');
----
fund_ticker,as_of_date,name,ticker,cusip,weight_percent,market_value,units,sec_type,currency,coupon_percent,maturity_date,next_call_date,rating

query T
SELECT column_type FROM (DESCRIBE SELECT * FROM iv.holdings WHERE fund_ticker = 'RSP') WHERE column_name = 'as_of_date';
----
DATE

# --- Live invariants (hit Invesco). ---

# Partition pushdown: WHERE fund_ticker = 'RSP' fetches that fund's holdings, weight-descending.
query I
SELECT (count(*) > 100 AND max(weight_percent) > 0 AND bool_and(fund_ticker = 'RSP'))::INT
FROM iv.holdings WHERE fund_ticker = 'RSP';
----
1

# Every row of a fund carries the same reported as-of date.
query I
SELECT (count(DISTINCT as_of_date) = 1 AND max(as_of_date) IS NOT NULL)::INT
FROM iv.holdings WHERE fund_ticker = 'RSP';
----
1

# Multiple partitions at once: fund_ticker IN (...) fans out to two funds.
query I
SELECT (count(DISTINCT fund_ticker) = 2)::INT FROM iv.holdings WHERE fund_ticker IN ('RSP', 'SPHQ');
----
1

# An unfiltered scan streams EVERY fund's holdings (one partition per fund). LIMIT short-circuits
# the stream after the first partition, so this stays cheap (no full fan-out).
query I
SELECT (count(*) >= 1)::INT FROM (SELECT * FROM iv.holdings LIMIT 5);
----
1

# The backing scan function also works directly (pushdown). It shares the `holdings` name with the
# table; called WITH parens it resolves to the table function.
query I
SELECT (count(*) > 100)::INT FROM iv.holdings() WHERE fund_ticker = 'RSP';
----
1
